---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout
  title="Fastlane Synthetics | Authorized AMSOIL Dealer"
  description="Fastlane Synthetics helps you find the right AMSOIL products for your needs."
>
  <main class="min-h-screen bg-[#f5f5f5] text-slate-900">
    <SiteHeader currentPath="/" />

    <section class="bg-white">
      <div class="mx-auto grid max-w-4xl gap-10 px-6 py-14 md:grid-cols-2 md:items-center md:px-10 md:py-16">
        <div class="flex justify-center md:justify-start">
          <img
            src="/logo.jpg"
            alt="Fastlane Synthetics logo"
            class="h-auto w-full max-w-md object-contain"
          />
        </div>

        <div class="text-center md:text-left">
          <h1 class="text-2xl font-black leading-tight text-[#13233d] md:text-4xl">
            Trusted AMSOIL product guidance for everyday drivers and hard-working equipment.
          </h1>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center md:justify-start">
            <a
              href="/how-to-order"
              class="inline-flex items-center justify-center rounded-xl bg-[#ef1c25] px-8 py-4 text-lg font-black text-white shadow-md transition hover:bg-[#d8151d]"
            >
              Shop AMSOIL
            </a>

            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-xl bg-[#0d47b5] px-8 py-4 text-lg font-black text-white shadow-md transition hover:bg-[#0a3a92]"
            >
              Find Your Oil
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e5d37a] bg-[#f6f1dc]">
      <div class="mx-auto max-w-5xl px-6 py-8 text-center md:px-10">
        <p class="text-lg leading-8 text-[#1b2a41]">
          <span class="font-black">A note on ordering:</span> Fastlane Synthetics helps customers
          identify the right AMSOIL products and provides a straightforward path to ordering
          through AMSOIL. We focus on practical support, helpful answers, and cleaner product guidance.
        </p>
      </div>
    </section>

    <section class="bg-[#f5f5f5]">
      <div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
        <div class="text-center">
          <h2 class="text-4xl font-black text-[#13233d] md:text-5xl">
            Why customers choose Fastlane Synthetics
          </h2>
          <p class="mt-4 text-xl text-slate-600">
            Straightforward support, trusted AMSOIL products, and a simpler buying path.
          </p>
        </div>

        <div class="mt-12 grid gap-8 md:grid-cols-4">
          <div class="text-center">
            <div class="mx-auto flex h-28 w-28 items-center justify-center rounded-full bg-[#ef1c25] text-4xl font-black text-white shadow-md">
              1:1
            </div>
            <h3 class="mt-5 text-2xl font-black text-[#17253d]">Guidance</h3>
            <p class="mt-2 text-lg text-slate-600">
              Practical product help for real-world use.
            </p>
          </div>

          <div class="text-center">
            <div class="mx-auto flex h-28 w-28 items-center justify-center rounded-full bg-[#0d47b5] text-4xl font-black text-white shadow-md">
              Fit
            </div>
            <h3 class="mt-5 text-2xl font-black text-[#17253d]">Application Match</h3>
            <p class="mt-2 text-lg text-slate-600">
              Recommendations based on what you drive or run.
            </p>
          </div>

          <div class="text-center">
            <div class="mx-auto flex h-28 w-28 items-center justify-center rounded-full bg-[#ef1c25] text-4xl font-black text-white shadow-md">
              Direct
            </div>
            <h3 class="mt-5 text-2xl font-black text-[#17253d]">Ordering Path</h3>
            <p class="mt-2 text-lg text-slate-600">
              A cleaner route to ordering through AMSOIL.
            </p>
          </div>

          <div class="text-center">
            <div class="mx-auto flex h-28 w-28 items-center justify-center rounded-full bg-[#0d47b5] text-4xl font-black text-white shadow-md">
              Local
            </div>
            <h3 class="mt-5 text-2xl font-black text-[#17253d]">Support</h3>
            <p class="mt-2 text-lg text-slate-600">
              Independent dealer help from Suwanee, Georgia.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
        <div class="grid gap-6 md:grid-cols-3">
          <div class="rounded-3xl border border-slate-300 bg-white p-8 shadow-sm">
            <p class="mb-4 text-sm font-black uppercase tracking-[0.24em] text-[#0d47b5]">Step 1</p>
            <h3 class="mb-4 text-3xl font-black text-[#13233d]">Tell us what you use</h3>
            <p class="text-lg leading-8 text-slate-600">
              Share your vehicle, equipment, or application so we can narrow the options.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-300 bg-white p-8 shadow-sm">
            <p class="mb-4 text-sm font-black uppercase tracking-[0.24em] text-[#c69214]">Step 2</p>
            <h3 class="mb-4 text-3xl font-black text-[#13233d]">Get product guidance</h3>
            <p class="text-lg leading-8 text-slate-600">
              We help point you toward AMSOIL products that fit your needs.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-300 bg-white p-8 shadow-sm">
            <p class="mb-4 text-sm font-black uppercase tracking-[0.24em] text-[#ef1c25]">Step 3</p>
            <h3 class="mb-4 text-3xl font-black text-[#13233d]">Order through AMSOIL</h3>
            <p class="text-lg leading-8 text-slate-600">
              Pricing and checkout are handled directly through AMSOIL.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
