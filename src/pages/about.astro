---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout
  title="About | Fastlane Synthetics"
  description="About Fastlane Synthetics, an independently owned AMSOIL dealership serving Georgia with nationwide shipping."
>
  <main class="min-h-screen bg-white text-slate-900">
    <SiteHeader currentPath="/about" />

    <section class="relative overflow-hidden bg-slate-900">
  <img src="/amsoilbackgroundabout.png"
    alt="AMSOIL background"
    class="absolute inset-0 h-full w-full object-cover object-bottom opacity-75"
  />
  <div class="absolute inset-0 bg-slate-950/40"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 py-16 md:px-10 md:py-20">
    <div class="max-w-4xl">
      <p class="text-sm font-bold uppercase tracking-[0.24em] text-cyan-300">
        About Fastlane Synthetics
      </p>

      <h1 class="mt-4 text-4xl font-black leading-tight text-white md:text-6xl">
        Serving Georgia & Nationwide Shipping
      </h1>

      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-200">
        Fastlane Synthetics is an independent AMSOIL dealership focused on helping drivers, riders,
        and equipment owners choose the right synthetic lubricant products without unnecessary confusion.
      </p>
    </div>
  </div>
</section>

    <section class="bg-slate-50">
      <div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
        <div class="grid gap-6 md:grid-cols-2">
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <h2 class="text-2xl font-black text-slate-900">What we do</h2>
            <p class="mt-4 leading-8 text-slate-600">
              We provide practical product guidance for daily drivers, motorcycles, powersports equipment,
              diesel applications, and other vehicles and equipment that need dependable lubrication support.
            </p>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <h2 class="text-2xl font-black text-slate-900">Who we help</h2>
            <p class="mt-4 leading-8 text-slate-600">
              We help customers across Georgia and beyond who want clear direction on AMSOIL products
              and a simpler path to ordering the right fit.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
        <div class="grid gap-10 rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm md:grid-cols-[1.1fr_0.9fr] md:p-12">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.24em] text-[#005baa]">
              Our Approach
            </p>
            <h2 class="mt-4 text-3xl font-black leading-tight text-slate-900 md:text-5xl">
              Simple, useful, and customer-focused
            </h2>
            <p class="mt-5 text-lg leading-8 text-slate-600">
              Fastlane Synthetics is built around clear information, practical recommendations,
              and a cleaner path to finding AMSOIL products that fit the application.
            </p>
            <p class="mt-5 text-lg leading-8 text-slate-600">
              Orders are completed directly through AMSOIL, and this website does not display AMSOIL product pricing.
            </p>
          </div>

          <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h3 class="text-lg font-black text-slate-900">
              Why customers appreciate this approach
            </h3>

            <ul class="mt-5 space-y-4 text-slate-700">
              <li class="flex gap-3"><span class="mt-1 text-[#005baa]">✓</span><span>Clear product guidance without unnecessary clutter</span></li>
              <li class="flex gap-3"><span class="mt-1 text-[#005baa]">✓</span><span>Support for a wide range of vehicles and equipment</span></li>
              <li class="flex gap-3"><span class="mt-1 text-[#005baa]">✓</span><span>A direct path to ordering through AMSOIL</span></li>
              <li class="flex gap-3"><span class="mt-1 text-[#005baa]">✓</span><span>Helpful information for both new and experienced AMSOIL customers</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-slate-950">
      <div class="absolute inset-0 bg-slate-950/80"></div>

      <div class="relative mx-auto max-w-7xl px-6 py-14 md:px-10 md:py-16">
        <div class="max-w-3xl">
          <p class="mb-4 text-sm font-bold uppercase tracking-[0.24em] text-cyan-300">
            Next Step
          </p>
          <h2 class="text-3xl font-black text-white md:text-5xl">
            Need help finding the right AMSOIL product?
          </h2>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-200">
            Visit the ordering page or reach out directly if you want help narrowing down the right option for your vehicle or equipment.
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href="/how-to-order"
              class="inline-flex items-center justify-center rounded-xl bg-[#ef1c25] px-8 py-4 text-base font-bold text-white transition hover:bg-[#d8151d]"
            >
              How to Order
            </a>

            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-xl border border-white/20 px-8 py-4 text-base font-bold text-white transition hover:bg-white/10"
            >
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>