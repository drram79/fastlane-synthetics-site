---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout
  title="Contact | Fastlane Synthetics"
  description="Contact Fastlane Synthetics for AMSOIL product guidance and support."
>
  <main class="min-h-screen bg-white text-slate-900">
    <SiteHeader currentPath="/contact" />

    <section class="bg-white">
      <div class="mx-auto max-w-4xl px-6 py-16 md:px-10 md:py-20">
        <div class="max-w-3xl">
          <p class="text-sm font-bold uppercase tracking-[0.24em] text-[#005baa]">
            Contact Us
          </p>
          <h1 class="mt-4 text-4xl font-black leading-tight text-slate-900 md:text-6xl">
            Have questions?
          </h1>
          <p class="mt-5 text-lg leading-8 text-slate-600">
            Let us know how we can help with AMSOIL products, ordering, synthetic lubricants,
            or general support.
          </p>
        </div>

        <div class="mt-12 max-w-3xl">
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="grid gap-6 rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm md:grid-cols-2"
          >
            <input type="hidden" name="access_key" value="c0fab517-e35c-4a09-9cdc-e825ff12457c" />
            <input
              type="hidden"
              name="subject"
              value="New Fastlane Synthetics contact form submission"
            />
            <input
              type="hidden"
              name="from_name"
              value="Fastlane Synthetics Contact Form"
            />
            <input
              type="hidden"
              name="redirect"
              value="https://fastlanesynthetics.com/contact?sent=1"
            />
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display:none"
              tabindex="-1"
              autocomplete="off"
            />

            <div>
              <label for="name" class="mb-2 block text-sm font-bold text-slate-900">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-[#005baa]"
              />
            </div>

            <div>
              <label for="email" class="mb-2 block text-sm font-bold text-slate-900">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-[#005baa]"
              />
            </div>

            <div class="md:col-span-2">
              <label for="message" class="mb-2 block text-sm font-bold text-slate-900">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-[#005baa]"
              ></textarea>
            </div>

            <div class="md:col-span-2">
              <button
                type="submit"
                class="inline-flex items-center justify-center rounded-xl bg-[#005baa] px-8 py-4 text-base font-bold text-white transition hover:bg-[#004a8c]"
              >
                Send Message
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
</Layout>